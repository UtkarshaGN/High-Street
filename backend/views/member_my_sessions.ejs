<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/head.ejs") %>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Sessions</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      .sortable:hover {
        cursor: pointer;
        background-color: #f9fafb;
      }
      .sort-icon {
        display: inline-block;
        margin-left: 8px;
        opacity: 0.6;
      }
      @media (max-width: 767px) {
        #sessions-table thead {
          display: none;
        }
        #sessions-table,
        #sessions-table tbody,
        #sessions-table tr {
          display: block;
          width: 100%;
        }
        #sessions-table tr {
          margin-bottom: 1rem;
          border: 1px solid #e5e7eb;
          border-radius: 0.5rem;
          padding: 1rem;
        }
        #sessions-table td {
          display: flex;
          justify-content: space-between;
          align-items: center;
          padding: 0.75rem 0.25rem;
          border-bottom: 1px solid #f3f4f6;
          text-align: right;
        }
        #sessions-table td:last-child {
          border-bottom: none;
        }
        #sessions-table td::before {
          content: attr(data-label);
          font-weight: 600;
          text-align: left;
          padding-right: 1rem;
        }
        #sessions-table td p,
        #sessions-table td span,
        #sessions-table td form {
          max-width: 60%;
          text-align: right;
        }
        #sessions-table td[data-label="Cancel"] form,
        #sessions-table td[data-label="Cancel"] button {
          width: 100%;
        }
      }
    </style>
  </head>
  <body class="bg-gray-100">
    <%- include("partials/header.ejs") %>
    <div class="flex flex-col md:flex-row min-h-screen">
      <%- include("partials/memberdashboard.ejs", { path: locals.path }) %>
      <main class="flex-1 p-4 md:p-8">
        <div class="bg-white p-4 sm:p-6 rounded-2xl shadow-sm">
          <div class="mb-6">
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-800">
              My Sessions
            </h1>
          </div>
          <div>
            <table class="min-w-full leading-normal" id="sessions-table">
              <thead>
                <tr>
                  <th
                    class="px-5 py-4 border-b-2 bg-gray-50 text-left text-xs font-semibold uppercase tracking-wider"
                  >
                    <a
                      href="/member/my-sessions?sortBy=sessionName&order=asc"
                      class="hover:text-blue-600"
                      >Session Name <span class="sort-icon">▲</span></a
                    >
                  </th>
                  <th
                    class="px-5 py-4 border-b-2 bg-gray-50 text-left text-xs font-semibold uppercase tracking-wider"
                  >
                    <a
                      href="/member/my-sessions?sortBy=time&order=asc"
                      class="hover:text-blue-600"
                      >Time <span class="sort-icon">▲</span></a
                    >
                  </th>
                  <th
                    class="px-5 py-4 border-b-2 bg-gray-50 text-left text-xs font-semibold uppercase tracking-wider"
                  >
                    <a
                      href="/member/my-sessions?sortBy=location&order=asc"
                      class="hover:text-blue-600"
                      >Location <span class="sort-icon">▲</span></a
                    >
                  </th>
                  <th
                    class="px-5 py-4 border-b-2 bg-gray-50 text-left text-xs font-semibold uppercase tracking-wider"
                  >
                    <a
                      href="/member/my-sessions?sortBy=trainer&order=asc"
                      class="hover:text-blue-600"
                      >Trainer <span class="sort-icon">▲</span></a
                    >
                  </th>
                  <th
                    class="px-5 py-4 border-b-2 bg-gray-50 text-left text-xs font-semibold uppercase tracking-wider"
                  >
                    Booking Status
                  </th>
                  <th
                    class="px-5 py-4 border-b-2 bg-gray-50 text-center text-xs font-semibold uppercase tracking-wider"
                  >
                    Cancel
                  </th>
                </tr>
              </thead>
              <tbody>
                <% if(bookings && bookings.length > 0) { %> <% for(const booking
                of bookings) { %>
                <tr class="hover:bg-gray-50">
                  <td data-label="Session" class="px-5 py-4 border-b text-sm">
                    <p><%= booking.activityName %></p>
                  </td>
                  <td data-label="Time" class="px-5 py-4 border-b text-sm">
                    <p><%= booking.startTime.substring(0, 5) %></p>
                  </td>
                  <td data-label="Location" class="px-5 py-4 border-b text-sm">
                    <p><%= booking.locationName %></p>
                  </td>
                  <td data-label="Trainer" class="px-5 py-4 border-b text-sm">
                    <p><%= booking.trainerName %></p>
                  </td>
                  <td data-label="Status" class="px-5 py-4 border-b text-sm">
                    <span
                      class="relative inline-block px-3 py-1 font-semibold leading-tight text-green-900"
                    >
                      <span
                        aria-hidden
                        class="absolute inset-0 bg-green-200 opacity-50 rounded-full"
                      ></span>
                      <span class="relative">Confirmed</span>
                    </span>
                  </td>
                  <td
                    data-label="Cancel"
                    class="px-5 py-4 border-b text-sm text-center"
                  >
                    <form
                      action="/member/cancel-booking/<%= booking.bookingId %>"
                      method="post"
                      onsubmit="return confirm('Are you sure?');"
                    >
                      <button
                        type="submit"
                        class="text-red-600 hover:text-red-900 font-semibold py-1 px-3 rounded-lg hover:bg-red-100"
                      >
                        Cancel
                      </button>
                    </form>
                  </td>
                </tr>
                <% } %> <% } else { %>
                <tr>
                  <td colspan="6" class="text-center py-10 text-gray-500">
                    You have no booked sessions.
                  </td>
                </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </main>
    </div>
    <%- include("partials/footer.ejs") %>
  </body>
</html>
