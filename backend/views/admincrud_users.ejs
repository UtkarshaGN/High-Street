<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/head.ejs") %>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Manage Users</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      .sortable:hover {
        cursor: pointer;
background-color: #f9fafb;
      }
      .sort-icon {
        display: inline-block;
margin-left: 8px;
        opacity: 0.6;
      }
      @media (max-width: 767px) {
        #users-table thead {
          display: none;
}
        #users-table,
        #users-table tbody,
        #users-table tr {
          display: block;
width: 100%;
        }
        #users-table tr {
          margin-bottom: 1rem;
border: 1px solid #e5e7eb;
          border-radius: 0.5rem;
          padding: 1rem;
        }
        #users-table td {
          display: flex;
justify-content: space-between;
          align-items: center;
          padding: 0.75rem 0.25rem;
          border-bottom: 1px solid #f3f4f6;
          text-align: right;
}
        #users-table tr:hover {
          background-color: transparent;
}
        #users-table td:last-child {
          border-bottom: none;
}
        #users-table td::before {
          content: attr(data-label);
font-weight: 600;
          text-align: left;
          padding-right: 1rem;
        }
        #users-table td p,
        #users-table td a {
          white-space: normal;
word-break: break-word;
          max-width: 60%;
        }
        #users-table td[data-label="Actions"] .flex {
          justify-content: flex-end;
width: 100%;
        }
      }
    </style>
  </head>
  <body class="bg-gray-100">
    <%- include("partials/header.ejs") %>

    <div class="flex flex-col md:flex-row min-h-screen">
      <%- include("partials/admindashboard.ejs") %>

      <main class="flex-1 p-4 md:p-8">
        <div class="bg-white p-4 sm:p-6 rounded-2xl shadow-sm">
          <div
            class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4"
          >
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-800">
              Manage Users
            </h1>
            <a
              href="/user/add"
              class="w-full sm:w-auto bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-5 rounded-lg shadow-md transition-transform transform hover:scale-105 flex items-center justify-center gap-2"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                viewBox="0 0 20 20"
                fill="currentColor"
              >
                <path
                  fill-rule="evenodd"
                  d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z"
                  clip-rule="evenodd"
                />
              </svg>
              <span>Add New User</span>
            </a>
          </div>

          <div>
            <table class="min-w-full leading-normal" id="users-table">
              <thead>
                <tr>
                  <th
                    class="px-5 py-4 border-b-2 border-gray-200 bg-gray-50 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider"
                  >
                    <a
                      href="/user?sortBy=firstName&order=asc"
                      class="hover:text-blue-600"
                      >First Name <span class="sort-icon">▲</span></a
                    >
                  </th>
                  <th
                    class="px-5 py-4 border-b-2 border-gray-200 bg-gray-50 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider"
                  >
                    <a
                      href="/user?sortBy=lastName&order=asc"
                      class="hover:text-blue-600"
                      >Last Name <span class="sort-icon">▲</span></a
                    >
                  </th>
                  <th
                    class="px-5 py-4 border-b-2 border-gray-200 bg-gray-50 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider"
                  >
                    Phone
                  </th>
                  <th
                    class="px-5 py-4 border-b-2 border-gray-200 bg-gray-50 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider"
                  >
                    <a
                      href="/user?sortBy=username&order=asc"
                      class="hover:text-blue-600"
                      >Username <span class="sort-icon">▲</span></a
                    >
                  </th>
                  <th
                    class="px-5 py-4 border-b-2 border-gray-200 bg-gray-50 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider"
                  >
                    <a
                      href="/user?sortBy=role&order=asc"
                      class="hover:text-blue-600"
                      >Role <span class="sort-icon">▲</span></a
                    >
                  </th>
                  <th
                    class="px-5 py-4 border-b-2 border-gray-200 bg-gray-50 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider"
                  >
                    Actions
                  </th>
                </tr>
              </thead>
              <tbody>
                <% if(users && users.length > 0) { %> <% for(const user of
                users) { %>
                <tr class="hover:bg-gray-50 md:hover:bg-gray-50">
                  <td
                    data-label="First Name"
                    class="px-5 py-4 border-b border-gray-200 text-sm"
                  >
                    <p class="text-gray-900"><%= user.firstName %></p>
                  </td>
                  <td
                    data-label="Last Name"
                    class="px-5 py-4 border-b border-gray-200 text-sm"
                  >
                    <p class="text-gray-900"><%= user.lastName %></p>
                  </td>
                  <td
                    data-label="Phone"
                    class="px-5 py-4 border-b border-gray-200 text-sm"
                  >
                    <p class="text-gray-900"><%= user.phone || 'N/A' %></p>
                  </td>
                  <td
                    data-label="Username"
                    class="px-5 py-4 border-b border-gray-200 text-sm"
                  >
                    <p class="text-gray-900"><%= user.username %></p>
                  </td>
                  <td
                    data-label="Role"
                    class="px-5 py-4 border-b border-gray-200 text-sm"
                  >
                    <p class="text-gray-900 capitalize"><%= user.role %></p>
                  </td>
                  <td
                    data-label="Actions"
                    class="px-5 py-4 border-b border-gray-200 text-sm text-center"
                  >
                    <div class="flex item-center justify-center gap-4">
                      <a
                        href="/user/edit/<%= user.userId %>"
                        class="p-1 text-blue-600 hover:text-blue-900 transition-colors"
                      >
                        <svg
                          class="w-5 h-5"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.536L16.732 3.732z"
                          ></path>
                        </svg>
                      </a>
                      <form
                        action="/user/<%= user.userId %>"
                        method="post"
                        onsubmit="return confirm('Are you sure you want to delete this user?');"
                      >
                        <input type="hidden" name="action" value="delete" />
                        <button
                          type="submit"
                          class="p-1 text-red-600 hover:text-red-900 transition-colors"
                        >
                          <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
                            ></path>
                          </svg>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% } %> <% } else { %>
                <tr>
                  <td colspan="6" class="text-center py-10 text-gray-500">
                    No users found.
                  </td>
                </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>