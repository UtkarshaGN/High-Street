<aside class="w-full md:w-64 bg-white p-6 border-b md:border-r border-gray-200">
  <h2 class="text-xl font-bold text-gray-800 border-b-2 border-orange-500 pb-2 mb-6">
    Member Dashboard
  </h2>
  <nav class="space-y-2">
    <a href="/member/sessions" class="block py-2 px-4 rounded transition duration-200 <%= locals.path === ('/member/sessions') ? 'font-bold text-orange-600 bg-orange-50' : 'text-gray-600 hover:bg-gray-100' %>">Weekly Calendar</a>
    <a href="/member/my-sessions" class="block py-2 px-4 rounded transition duration-200 <%= locals.path.startsWith('/member/my-sessions') ? 'font-bold text-orange-600 bg-orange-50' : 'text-gray-600 hover:bg-gray-100' %>">My Sessions</a>
    <a href="/member/my-posts" class="block py-2 px-4 rounded transition duration-200 <%= locals.path.startsWith('/member/my-posts') ? 'font-bold text-orange-600 bg-orange-50' : 'text-gray-600 hover:bg-gray-100' %>">My Blog Posts</a>
    <a href="/auth/logout" class="block py-2 px-4 rounded transition duration-200 text-gray-600 hover:bg-gray-100">Log Out</a>
  </nav>
</aside>