<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/head.ejs") %>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Manage Bookings</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      .sortable:hover {
        cursor: pointer;
        background-color: #f9fafb;
      }
      .sort-icon {
        display: inline-block;
        margin-left: 8px;
        opacity: 0.6;
      }
      @media (max-width: 767px) {
        #bookings-table thead {
          display: none;
        }
        #bookings-table,
        #bookings-table tbody,
        #bookings-table tr {
          display: block;
          width: 100%;
        }
        #bookings-table tr {
          margin-bottom: 1rem;
          border: 1px solid #e5e7eb;
          border-radius: 0.5rem;
          padding: 1rem;
        }
        #bookings-table td {
          display: flex;
          justify-content: space-between;
          align-items: center;
          padding: 0.75rem 0.25rem;
          border-bottom: 1px solid #f3f4f6;
          text-align: right;
        }
        #bookings-table tr:hover {
          background-color: transparent;
        }
        #bookings-table td:last-child {
          border-bottom: none;
        }
        #bookings-table td::before {
          content: attr(data-label);
          font-weight: 600;
          text-align: left;
          padding-right: 1rem;
        }
        #bookings-table td p,
        #bookings-table td .relative,
        #bookings-table td a {
          white-space: normal;
          word-break: break-word;
          max-width: 60%;
          text-align: right;
        }
        #bookings-table td[data-label="Actions"] .flex {
          justify-content: flex-end;
          width: 100%;
        }
      }
    </style>
  </head>
  <body class="bg-gray-100">
    <%- include("partials/header.ejs") %>

    <div class="flex flex-col md:flex-row min-h-screen">
      <%- include("partials/admindashboard.ejs") %>

      <main class="flex-1 p-4 md:p-8">
        <div class="bg-white p-4 sm:p-6 rounded-2xl shadow-sm">
          <div
            class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4"
          >
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-800">
              Manage Bookings
            </h1>
            <a
              href="/booking/add"
              class="w-full sm:w-auto bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-5 rounded-lg shadow-md transition-transform transform hover:scale-105 flex items-center justify-center gap-2"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                viewBox="0 0 20 20"
                fill="currentColor"
              >
                <path
                  fill-rule="evenodd"
                  d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z"
                  clip-rule="evenodd"
                />
              </svg>
              <span>Add Booking</span>
            </a>
          </div>

          <form action="/booking" method="get" class="mb-6">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
              <div>
                <label
                  for="member"
                  class="block text-sm font-medium text-gray-700"
                  >Member</label
                >
                <select
                  name="member"
                  id="member"
                  class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2"
                >
                  <option value="">All Members</option>
                  <% users.forEach(user => { %>
                  <option value="<%= user.userId %>">
                    <%= user.firstName %> <%= user.lastName %>
                  </option>
                  <% }) %>
                </select>
              </div>
              <div>
                <label
                  for="session"
                  class="block text-sm font-medium text-gray-700"
                  >Session</label
                >
                <select
                  name="session"
                  id="session"
                  class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2"
                >
                  <option value="">All Sessions</option>
                  <% sessions.forEach(session => { %>
                  <option value="<%= session.session.sessionId %>">
                    <%= session.activity.activityName %>
                  </option>
                  <% }) %>
                </select>
              </div>
              <div>
                <label
                  for="status"
                  class="block text-sm font-medium text-gray-700"
                  >Status</label
                >
                <select
                  name="status"
                  id="status"
                  class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2"
                >
                  <option value="">All</option>
                  <option value="booked">Booked</option>
                  <option value="cancelled">Cancelled</option>
                </select>
              </div>
              <div>
                <label
                  for="date"
                  class="block text-sm font-medium text-gray-700"
                  >Date</label
                >
                <input
                  type="date"
                  name="date"
                  id="date"
                  class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2"
                />
              </div>
              <div class="flex items-end">
                <button
                  type="submit"
                  class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg shadow-md"
                >
                  Filter
                </button>
              </div>
            </div>
          </form>

          <div>
            <table class="min-w-full leading-normal" id="bookings-table">
              <thead>
                <tr>
                  <th
                    class="px-5 py-4 border-b-2 border-gray-200 bg-gray-50 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider"
                  >
                    <a
                      href="/booking?sortBy=memberName&order=asc"
                      class="hover:text-blue-600"
                      >Member Name <span class="sort-icon">▲</span></a
                    >
                  </th>
                  <th
                    class="px-5 py-4 border-b-2 border-gray-200 bg-gray-50 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider"
                  >
                    <a
                      href="/booking?sortBy=session&order=asc"
                      class="hover:text-blue-600"
                      >Session <span class="sort-icon">▲</span></a
                    >
                  </th>
                  <th
                    class="px-5 py-4 border-b-2 border-gray-200 bg-gray-50 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider"
                  >
                    <a
                      href="/booking?sortBy=sessionDate&order=desc"
                      class="hover:text-blue-600"
                      >Date <span class="sort-icon">▲</span></a
                    >
                  </th>

                  <th
                    class="px-5 py-4 border-b-2 border-gray-200 bg-gray-50 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider"
                  >
                    <a
                      href="/booking?sortBy=status&order=asc"
                      class="hover:text-blue-600"
                      >Status <span class="sort-icon">▲</span></a
                    >
                  </th>

                  <th
                    class="px-5 py-4 border-b-2 border-gray-200 bg-gray-50 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider"
                  >
                    Actions
                  </th>
                </tr>
              </thead>
              <tbody>
                <% if(bookings && bookings.length > 0) { %> <% for(const booking
                of bookings) { %>
                <tr class="hover:bg-gray-50 md:hover:bg-gray-50">
                  <td
                    data-label="Member Name"
                    class="px-5 py-4 border-b border-gray-200 text-sm"
                  >
                    <p class="text-gray-900">
                      <%= booking.firstName %> <%= booking.lastName %>
                    </p>
                  </td>
                  <td
                    data-label="Session"
                    class="px-5 py-4 border-b border-gray-200 text-sm"
                  >
                    <p class="text-gray-900"><%= booking.activityName %></p>
                  </td>

                  <td
                    data-label="Date"
                    class="px-5 py-4 border-b border-gray-200 text-sm"
                  >
                    <p class="text-gray-900">
                      <%= new Date(booking.sessionDate).toLocaleDateString() %>
                      at <%= booking.startTime ? booking.startTime.substring(0,
                      5) : 'N/A' %>
                    </p>
                  </td>
                  <td
                    data-label="Status"
                    class="px-5 py-4 border-b border-gray-200 text-sm"
                  >
                    <span
                      class="relative inline-block px-3 py-1 font-semibold leading-tight <%= booking.status === 'booked' ? 'text-green-900' : 'text-red-900' %>"
                    >
                      <span
                        aria-hidden
                        class="absolute inset-0 <%= booking.status === 'booked' ? 'bg-green-200' : 'bg-red-200' %> opacity-50 rounded-full"
                      ></span>
                      <span class="relative capitalize"
                        ><%= booking.status %></span
                      >
                    </span>
                  </td>
                  <td
                    data-label="Actions"
                    class="px-5 py-4 border-b border-gray-200 text-sm text-center"
                  >
                    <div class="flex items-center justify-center gap-4">
                      <a
                        href="/booking/edit/<%= booking.bookingId %>"
                        class="p-1 text-blue-600 hover:text-blue-900 transition-colors"
                      >
                        <svg
                          class="w-5 h-5"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.536L16.732 3.732z"
                          ></path>
                        </svg>
                      </a>
                      <form
                        action="/booking/<%= booking.bookingId %>"
                        method="post"
                        onsubmit="return confirm('Are you sure?');"
                      >
                        <input type="hidden" name="action" value="delete" />
                        <button
                          type="submit"
                          class="p-1 text-red-600 hover:text-red-900 transition-colors"
                        >
                          <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
                            ></path>
                          </svg>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% } %> <% } else { %>
                <tr>
                  <td colspan="5" class="text-center py-10 text-gray-500">
                    No bookings found.
                  </td>
                </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
