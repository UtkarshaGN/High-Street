<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= post ? 'Edit' : 'Add' %> Blog Post</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">
    <%- include("partials/header.ejs") %>

    <div class="flex flex-col md:flex-row min-h-screen">
        <%- include("partials/admindashboard.ejs") %>
        
        <main class="flex-1 p-4 md:p-8">
            <div class="bg-white p-4 sm:p-6 rounded-2xl shadow-sm">
                <h2 class="text-2xl sm:text-3xl font-bold text-gray-800 mb-6"><%= post ? 'Edit' : 'Add New' %> Post</h2>
                
                <% if (post) { %>
                    <form action="/post/<%= post.postId %>" method="post" class="space-y-6">
                <% } else { %>
                    <form action="/post" method="post" class="space-y-6">
                <% } %>
                    <div>
                        <label for="title" class="block text-sm font-medium text-gray-700 mb-1">Title</label>
                        <input type="text" name="title" id="title" value="<%= post ? post.title : '' %>" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm p-3">
                    </div>
                    <div>
                        <label for="content" class="block text-sm font-medium text-gray-700 mb-1">Content</label>
                        <textarea name="content" id="content" rows="6" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm p-3"><%= post ? post.content : '' %></textarea>
                    </div>
                    
                    <div class="flex items-center justify-end space-x-4 pt-4">
                        <a href="/posts/manage" class="w-full sm:w-auto px-6 py-2 text-sm font-semibold text-gray-700 bg-gray-200 rounded-lg hover:bg-gray-300 text-center">Cancel</a>
                        <% if (post) { %>
                            <button type="submit" name="action" value="update" class="w-full sm:w-auto px-6 py-2 text-sm font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700">Update Post</button>
                        <% } else { %>
                            <button type="submit" name="action" value="create" class="w-full sm:w-auto px-6 py-2 text-sm font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700">Create Post</button>
                        <% } %>
                    </div>
                </form>
            </div>
        </main>
    </div>
</body>
</html>