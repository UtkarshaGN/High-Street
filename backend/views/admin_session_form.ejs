<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= session ? 'Edit' : 'Add' %> Session</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">
    <%- include("partials/header.ejs") %>

    <div class="flex flex-col md:flex-row min-h-screen">
        <%- include("partials/admindashboard.ejs") %>
        
        <main class="flex-1 p-4 md:p-8">
            <div class="bg-white p-4 sm:p-6 rounded-2xl shadow-sm">
                <h2 class="text-2xl sm:text-3xl font-bold text-gray-800 mb-6"><%= session ? 'Edit' : 'Add New' %> Session</h2>
                
                <form action="<%= session ? '/sessions/' + session.sessionId : '/sessions' %>" method="post" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label for="activityId" class="block text-sm font-medium text-gray-700 mb-1">Activity</label>
                            <select name="activityId" id="activityId" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-3">
                                <option value="">Select an activity...</option>
                                <% for(const activity of activities) { %>
                                    <option value="<%= activity.activityId %>" <%= session && session.activityId == activity.activityId ? 'selected' : '' %>><%= activity.activityName %></option>
                                <% } %>
                            </select>
                        </div>
                        <div>
                            <label for="locationId" class="block text-sm font-medium text-gray-700 mb-1">Location</label>
                            <select name="locationId" id="locationId" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-3">
                                <option value="">Select a location...</option>
                                <% for(const location of locations) { %>
                                    <option value="<%= location.locationId %>" <%= session && session.locationId == location.locationId ? 'selected' : '' %>><%= location.locationName %></option>
                                <% } %>
                            </select>
                        </div>
                        <div>
                            <label for="trainerId" class="block text-sm font-medium text-gray-700 mb-1">Trainer</label>
                            <select name="trainerId" id="trainerId" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-3">
                                <option value="">Select a trainer...</option>
                                <% for(const trainer of trainers) { %>
                                    <option value="<%= trainer.userId %>" <%= session && session.trainerId == trainer.userId ? 'selected' : '' %>><%= trainer.firstName %> <%= trainer.lastName %></option>
                                <% } %>
                            </select>
                        </div>
                        <div>
                            <label for="sessionDate" class="block text-sm font-medium text-gray-700 mb-1">Date</label>
                            <input type="date" name="sessionDate" id="sessionDate" value="<%= session ? session.sessionDate : '' %>" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-3" />
                        </div>
                        <div>
                            <label for="startTime" class="block text-sm font-medium text-gray-700 mb-1">Start Time</label>
                            <input type="time" name="startTime" id="startTime" value="<%= session ? session.startTime : '' %>" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-3" />
                        </div>
                        <div>
                            <label for="endTime" class="block text-sm font-medium text-gray-700 mb-1">End Time</label>
                            <input type="time" name="endTime" id="endTime" value="<%= session ? session.endTime : '' %>" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-3" />
                        </div>
                    </div>
                    
                    <div class="flex items-center justify-end space-x-4 pt-4">
                        <a href="/sessions" class="w-full sm:w-auto px-6 py-2 text-sm font-semibold text-gray-700 bg-gray-200 rounded-lg">Cancel</a>
                        <button type="submit" name="action" value="<%= session ? 'update' : 'create' %>" class="w-full sm:w-auto px-6 py-2 text-sm font-semibold text-white bg-blue-600 rounded-lg">
                            <%= session ? 'Update' : 'Create' %> Session
                        </button>
                    </div>
                </form>
            </div>
        </main>
    </div>
</body>
</html>