<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= user ? 'Edit' : 'Add' %> User</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">
    <%- include("partials/header.ejs") %>

    <div class="flex flex-col md:flex-row min-h-screen">
        <%- include("partials/admindashboard.ejs") %>
        
        <main class="flex-1 p-4 md:p-8">
            <div class="bg-white p-4 sm:p-6 rounded-2xl shadow-sm">
                <h2 class="text-2xl sm:text-3xl font-bold text-gray-800 mb-6"><%= user ? 'Edit' : 'Add New' %> User</h2>
                
                <% if (user) { %>
                    <form action="/user/<%= user.userId %>" method="post" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <% } else { %>
                    <form action="/user" method="post" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <% } %>
                    
                    <div>
                        <label for="firstName" class="block text-sm font-medium text-gray-700 mb-1">First Name</label>
                        <input type="text" name="firstName" id="firstName" value="<%= user ? user.firstName : '' %>" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm p-3">
                    </div>
                    <div>
                        <label for="lastName" class="block text-sm font-medium text-gray-700 mb-1">Last Name</label>
                        <input type="text" name="lastName" id="lastName" value="<%= user ? user.lastName : '' %>" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm p-3">
                    </div>
                    <div>
                        <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
                        <input type="text" name="phone" id="phone" value="<%= user ? user.phone : '' %>" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm p-3">
                    </div>
                    <div>
                        <label for="username" class="block text-sm font-medium text-gray-700 mb-1">Username</label>
                        <input type="text" name="username" id="username" value="<%= user ? user.username : '' %>" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm p-3">
                    </div>
                    <div>
                        <label for="password" class="block text-sm font-medium text-gray-700 mb-1">New Password</label>
                        <input type="password" name="password" id="password" placeholder="<%= user ? 'Leave blank to keep unchanged' : '' %>" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm p-3" <%= !user ? 'required' : '' %>>
                    </div>
                    <div>
                        <label for="role" class="block text-sm font-medium text-gray-700 mb-1">Role</label>
                        <select name="role" id="role" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm p-3">
                            <option value="admin" <%= user && user.role === 'admin' ? 'selected' : '' %>>Admin</option>
                            <option value="member" <%= user && user.role === 'member' ? 'selected' : '' %>>Member</option>
                            <option value="trainer" <%= user && user.role === 'trainer' ? 'selected' : '' %>>Trainer</option>
                        </select>
                    </div>

                    <div class="md:col-span-2 flex items-center justify-end space-x-4 pt-4">
                        <a href="/user" class="w-full sm:w-auto px-6 py-2 text-sm font-semibold text-gray-700 bg-gray-200 rounded-lg hover:bg-gray-300 text-center">Cancel</a>
                        <% if (user) { %>
                            <button type="submit" name="action" value="update" class="w-full sm:w-auto px-6 py-2 text-sm font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700">Update User</button>
                        <% } else { %>
                            <button type="submit" name="action" value="create" class="w-full sm:w-auto px-6 py-2 text-sm font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700">Create User</button>
                        <% } %>
                    </div>
                </form>
            </div>
        </main>
    </div>
</body>
</html>