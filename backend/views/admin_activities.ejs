<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/head.ejs") %>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Manage Activities</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      .sortable:hover {
        cursor: pointer;
        background-color: #f9fafb;
      }
      .sort-icon {
        display: inline-block;
        margin-left: 8px;
        opacity: 0.6;
      }
      @media (max-width: 767px) {
        #activities-table thead {
          display: none;
        }
        #activities-table,
        #activities-table tbody,
        #activities-table tr {
          display: block;
          width: 100%;
        }
        #activities-table tr {
          margin-bottom: 1rem;
          border: 1px solid #e5e7eb;
          border-radius: 0.5rem;
          padding: 1rem;
        }
        #activities-table td {
          display: flex;
          justify-content: space-between;
          align-items: center;
          padding: 0.75rem 0.25rem;
          border-bottom: 1px solid #f3f4f6;
          text-align: right;
        }
        #activities-table td:last-child {
          border-bottom: none;
        }
        #activities-table td::before {
          content: attr(data-label);
          font-weight: 600;
          text-align: left;
          padding-right: 1rem;
        }
        #activities-table td p,
        #activities-table td a {
          max-width: 60%;
        }
        #activities-table td[data-label="Actions"] .flex {
          justify-content: flex-end;
          width: 100%;
        }
      }
    </style>
  </head>
  <body class="bg-gray-100">
    <%- include("partials/header.ejs") %>
    <div class="flex flex-col md:flex-row min-h-screen">
      <%- include("partials/admindashboard.ejs") %>
      <main class="flex-1 p-4 md:p-8">
        <div class="bg-white p-4 sm:p-6 rounded-2xl shadow-sm">
          <div
            class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4"
          >
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-800">
              Manage Activities
            </h1>
            <a
              href="/activity/add"
              class="w-full sm:w-auto bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-5 rounded-lg shadow-md"
            >
              <span>Add Activity</span>
            </a>
          </div>
          <form action="/activity" method="get" class="mb-6">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
              <div>
                <label
                  for="activityName"
                  class="block text-sm font-medium text-gray-700"
                  >Activity Name</label
                >
                <input
                  type="text"
                  name="activityName"
                  id="activityName"
                  class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2"
                />
              </div>
              <div class="flex items-end">
                <button
                  type="submit"
                  class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg shadow-md"
                >
                  Filter
                </button>
              </div>
            </div>
          </form>
          <div>
            <table class="min-w-full leading-normal" id="activities-table">
              <thead>
                <tr>
                  <th
                    class="px-5 py-4 border-b-2 border-gray-200 bg-gray-50 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider"
                  >
                    <a
                      href="/activity?sortBy=activityName&order=asc"
                      class="hover:text-blue-600"
                      >Activity Name <span class="sort-icon">▲</span></a
                    >
                  </th>
                  <th
                    class="px-5 py-4 border-b-2 border-gray-200 bg-gray-50 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider"
                  >
                    Description
                  </th>
                  <th
                    class="px-5 py-4 border-b-2 border-gray-200 bg-gray-50 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider"
                  >
                    Actions
                  </th>
                </tr>
              </thead>
              <tbody>
                <% if(activities && activities.length > 0) { %> <% for(const
                activity of activities) { %>
                <tr class="hover:bg-gray-50">
                  <td
                    data-label="Activity Name"
                    class="px-5 py-4 border-b border-gray-200 text-sm"
                  >
                    <p><%= activity.activityName %></p>
                  </td>
                  <td
                    data-label="Description"
                    class="px-5 py-4 border-b border-gray-200 text-sm"
                  >
                    <p><%= activity.description %></p>
                  </td>
                  <td
                    data-label="Actions"
                    class="px-5 py-4 border-b border-gray-200 text-sm text-center"
                  >
                    <div class="flex items-center justify-center gap-4">
                      <a
                        href="/activity/edit/<%= activity.activityId %>"
                        class="p-1 text-blue-600 hover:text-blue-900"
                      >
                        <svg
                          class="w-5 h-5"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.536L16.732 3.732z"
                          ></path>
                        </svg>
                      </a>
                      <form
                        action="/activity/<%= activity.activityId %>"
                        method="post"
                        onsubmit="return confirm('Are you sure?');"
                      >
                        <input type="hidden" name="action" value="delete" />
                        <button
                          type="submit"
                          class="p-1 text-red-600 hover:text-red-900"
                        >
                          <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                          >
                            <path
                              d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
                            ></path>
                          </svg>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% } %> <% } else { %>
                <tr>
                  <td colspan="3" class="text-center py-10 text-gray-500">
                    No activities found.
                  </td>
                </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
