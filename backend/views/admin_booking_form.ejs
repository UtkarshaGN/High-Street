<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= booking ? 'Edit' : 'Add' %> Booking</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">
    <%- include("partials/header.ejs") %>

    <div class="flex flex-col md:flex-row min-h-screen">
        <%- include("partials/admindashboard.ejs") %>
        
        <main class="flex-1 p-4 md:p-8">
            <div class="bg-white p-4 sm:p-6 rounded-2xl shadow-sm">
                <h2 class="text-2xl sm:text-3xl font-bold text-gray-800 mb-6"><%= booking ? 'Edit' : 'Add New' %> Booking</h2>
                
                <form action="<%= booking ? '/booking/' + booking.bookingId : '/booking' %>" method="post" class="grid grid-cols-1 md:grid-cols-2 gap-6">

                    <div>
                        <label for="userId" class="block text-sm font-medium text-gray-700 mb-1">Member</label>
                        <select name="userId" id="userId" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-3">
                            <option value="">Select a member</option>
                            <% users.forEach(user => { %>
                                <option value="<%= user.userId %>" <% if (booking && booking.userId == user.userId) { %>selected<% } %>>
                                    <%= user.firstName %> <%= user.lastName %>
                                </option>
                            <% }) %>
                        </select>
                    </div>

                    <div>
                        <label for="sessionId" class="block text-sm font-medium text-gray-700 mb-1">Session</label>
                        <select name="sessionId" id="sessionId" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-3">
                            <option value="">Select a session</option>
                            <% sessions.forEach(session => { %>
                                <option value="<%= session.session.sessionId %>" <% if (booking && booking.sessionId == session.session.sessionId) { %>selected<% } %>>
                                    <%= session.activity.activityName %> on <%= new Date(session.session.sessionDate).toLocaleDateString() %>
                                </option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="md:col-span-2">
                        <label for="status" class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                        <select name="status" id="status" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-3">
                            <option value="booked" <% if (booking && booking.status === 'booked') { %>selected<% } %>>Booked</option>
                            <option value="cancelled" <% if (booking && booking.status === 'cancelled') { %>selected<% } %>>Cancelled</option>
                        </select>
                    </div>
                    
                    <div class="md:col-span-2 flex items-center justify-end space-x-4 pt-4">
                        <a href="/booking" class="w-full sm:w-auto px-6 py-2 text-sm font-semibold text-gray-700 bg-gray-200 rounded-lg">Cancel</a>
                        <button type="submit" name="action" value="<%= booking ? 'update' : 'create' %>" class="w-full sm:w-auto px-6 py-2 text-sm font-semibold text-white bg-blue-600 rounded-lg">
                            <%= booking ? 'Update' : 'Create' %> Booking
                        </button>
                    </div>
                </form>
            </div>
        </main>
    </div>
</body>
</html>