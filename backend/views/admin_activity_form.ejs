<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/head.ejs") %>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= activity ? 'Edit' : 'Add' %> Activity</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-gray-100">
    <%- include("partials/header.ejs") %>

    <div class="flex flex-col md:flex-row min-h-screen">
      <%- include("partials/admindashboard.ejs") %>

      <main class="flex-1 p-4 md:p-8">
        <div class="bg-white p-4 sm:p-6 rounded-2xl shadow-sm">
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-800 mb-6">
            <%= activity ? 'Edit' : 'Add New' %> Activity
          </h2>

          <form
            action="<%= activity ? '/activity/' + activity.activityId : '/activity' %>"
            method="post"
            class="space-y-6"
          >
            <div>
              <label
                for="activityName"
                class="block text-sm font-medium text-gray-700 mb-1"
                >Activity Name</label
              >
              <input
                type="text"
                name="activityName"
                id="activityName"
                value="<%= activity ? activity.activityName : '' %>"
                required
                class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-3"
              />
            </div>
            <div>
              <label
                for="description"
                class="block text-sm font-medium text-gray-700 mb-1"
                >Description</label
              >
              <textarea
                name="description"
                id="description"
                rows="4"
                required
                class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-3"
              >
<%= activity ? activity.description : '' %></textarea
              >
            </div>

            <div class="flex items-center justify-end space-x-4 pt-4">
              <a
                href="/activity"
                class="w-full sm:w-auto px-6 py-2 text-sm font-semibold text-gray-700 bg-gray-200 rounded-lg"
                >Cancel</a
              >
              <button
                type="submit"
                name="action"
                value="<%= activity ? 'update' : 'create' %>"
                class="w-full sm:w-auto px-6 py-2 text-sm font-semibold text-white bg-blue-600 rounded-lg"
              >
                <%= activity ? 'Update' : 'Create' %> Activity
              </button>
            </div>
          </form>
        </div>
      </main>
    </div>
  </body>
</html>
