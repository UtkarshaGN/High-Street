<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/head.ejs") %>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Manage Sessions</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      .sortable:hover {
        cursor: pointer;
background-color: #f9fafb;
      }
      .sort-icon {
        display: inline-block;
margin-left: 8px;
        opacity: 0.6;
      }
      @media (max-width: 767px) {
        #sessions-table thead {
          display: none;
}
        #sessions-table,
        #sessions-table tbody,
        #sessions-table tr {
          display: block;
width: 100%;
        }
        #sessions-table tr {
          margin-bottom: 1rem;
border: 1px solid #e5e7eb;
          border-radius: 0.5rem;
          padding: 1rem;
        }
        #sessions-table td {
          display: flex;
justify-content: space-between;
          align-items: center;
          padding: 0.75rem 0.25rem;
          border-bottom: 1px solid #f3f4f6;
          text-align: right;
}
        #sessions-table td:last-child {
          border-bottom: none;
}
        #sessions-table td::before {
          content: attr(data-label);
font-weight: 600;
          text-align: left;
          padding-right: 1rem;
        }
        #sessions-table td p,
        #sessions-table td a {
          max-width: 60%;
}
        #sessions-table td[data-label="Actions"] .flex {
          justify-content: flex-end;
width: 100%;
        }
      }
    </style>
  </head>
  <body class="bg-gray-100">
    <%- include("partials/header.ejs") %>
    <div class="flex flex-col md:flex-row min-h-screen">
      <%- include("partials/admindashboard.ejs") %>
      <main class="flex-1 p-4 md:p-8">
        <div class="bg-white p-4 sm:p-6 rounded-2xl shadow-sm">
          <div
            class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4"
          
>
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-800">
              Manage Sessions
            </h1>
            <a
              href="/sessions/add"
              class="w-full sm:w-auto bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-5 rounded-lg shadow-md"
        
    >
              <span>Add Session</span>
            </a>
          </div>

          <form action="/sessions" method="get" class="mb-6">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
              <div>
                <label for="startDate" class="block text-sm font-medium text-gray-700">Start Date</label>
                <input type="date" name="startDate" id="startDate" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2">
              </div>
              <div>
                <label for="endDate" class="block text-sm font-medium text-gray-700">End Date</label>
                <input type="date" name="endDate" id="endDate" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2">
              </div>
              <div>
                <label for="trainer" class="block text-sm font-medium text-gray-700">Trainer</label>
                <select name="trainer" id="trainer" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2">
                  <option value="">All Trainers</option>
                  <% trainers.forEach(trainer => { %>
                    <option value="<%= trainer.userId %>"><%= trainer.firstName %> <%= trainer.lastName %></option>
                  <% }) %>
                </select>
              </div>
              <div class="flex items-end">
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg shadow-md">Filter</button>
              </div>
            </div>
          </form>

          <div>
            <table class="min-w-full leading-normal" id="sessions-table">
              <thead>
                <tr>
    
              <th
                    class="px-5 py-4 border-b-2 bg-gray-50 text-left text-xs font-semibold uppercase tracking-wider"
                  >
                    <a
                    
  href="/sessions?sortBy=activity&order=asc"
                      class="hover:text-blue-600"
                      >Activity <span class="sort-icon">▲</span></a
                    >
                  </th>
              
    <th
                    class="px-5 py-4 border-b-2 bg-gray-50 text-left text-xs font-semibold uppercase tracking-wider"
                  >
                    <a
                      href="/sessions?sortBy=trainer&order=asc"
        
              class="hover:text-blue-600"
                      >Trainer <span class="sort-icon">▲</span></a
                    >
                  </th>
                  <th
      
              class="px-5 py-4 border-b-2 bg-gray-50 text-left text-xs font-semibold uppercase tracking-wider"
                  >
                    <a
                      href="/sessions?sortBy=location&order=asc"
                  
    class="hover:text-blue-600"
                      >Location <span class="sort-icon">▲</span></a
                    >
                  </th>
                  <th
                
    class="px-5 py-4 border-b-2 bg-gray-50 text-left text-xs font-semibold uppercase tracking-wider"
                  >
                    <a
                      href="/sessions?sortBy=sessionDate&order=desc"
                      class="hover:text-blue-600"
      
                >Date <span class="sort-icon">▲</span></a
                    >
                  </th>
                  <th
                    class="px-5 py-4 border-b-2 bg-gray-50 text-left text-xs 
font-semibold uppercase tracking-wider"
                  >
                    <a
                      href="/sessions?sortBy=startTime&order=asc"
                      class="hover:text-blue-600"
                
      >Start Time <span class="sort-icon">▲</span></a
                    >
                  </th>
                  <th
                    class="px-5 py-4 border-b-2 bg-gray-50 text-left text-xs font-semibold uppercase tracking-wider"
       
           >
                    <a
                      href="/sessions?sortBy=endTime&order=asc"
                      class="hover:text-blue-600"
                      >End Time <span 
class="sort-icon">▲</span></a
                    >
                  </th>
                  <th
                    class="px-5 py-4 border-b-2 bg-gray-50 text-center text-xs font-semibold uppercase tracking-wider"
                
  >
                    Actions
                  </th>
                </tr>
              </thead>
              <tbody>
                
<% if(sessions && sessions.length > 0) { %> <% for(const session
                of sessions) { %>
                <tr class="hover:bg-gray-50">
                  <td data-label="Activity" class="px-5 py-4 border-b text-sm">
                    <p><%= session.activityName %></p>
         
         </td>
                  <td data-label="Trainer" class="px-5 py-4 border-b text-sm">
                    <p><%= session.trainerName ||
'N/A' %></p>
                  </td>
                  <td data-label="Location" class="px-5 py-4 border-b text-sm">
                    <p><%= session.locationName %></p>
                  </td>
                  
<td data-label="Date" class="px-5 py-4 border-b text-sm">
                    <p>
                      <%= new Date(session.sessionDate).toLocaleDateString() %>
                    </p>
                  </td>
            
      <td
                    data-label="Start Time"
                    class="px-5 py-4 border-b text-sm"
                  >
                    <p class="text-gray-900">
           
           <%= session.startTime.substring(0, 5) %>
                    </p>
                  </td>
                  <td data-label="End Time" class="px-5 py-4 border-b text-sm">
                    <p class="text-gray-900">
   
                   <%= session.endTime.substring(0, 5) %>
                    </p>
                  </td>
                  <td
                    data-label="Actions"
  
                  class="px-5 py-4 border-b text-sm text-center"
                  >
                    <div class="flex items-center justify-center gap-4">
                      <a
              
          href="/sessions/edit/<%= session.sessionId %>"
                        class="p-1 text-blue-600 hover:text-blue-900"
                      >
                        <svg
                
          class="w-5 h-5"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
        
                >
                          <path
                            d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.536L16.732 3.732z"
                      
    ></path>
                        </svg>
                      </a>
                      <form
                        action="/sessions/<%= session.sessionId %>"
  
                      method="post"
                        onsubmit="return confirm('Are you sure?');"
>
                        <input type="hidden" name="action" value="delete" />
                        <button
                          type="submit"
                      
    class="p-1 text-red-600 hover:text-red-900"
                        >
                          <svg
                            class="w-5 h-5"
               
             fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                          >
  
                          <path
                              d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
                         
   ></path>
                          </svg>
                        </button>
                      </form>
                    </div>
     
             </td>
                </tr>
                <% } %> <% } else { %>
                <tr>
                  <td colspan="7" class="text-center py-10 text-gray-500">
          
          No sessions found.
</td>
                </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>